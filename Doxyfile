# Doxygen configuration for libkdtree (run from this directory: doxygen Doxyfile)
PROJECT_NAME           = libkdtree
PROJECT_BRIEF          = "Header-only k-d tree (C++20)"
PROJECT_NUMBER         = 0.7.1

OUTPUT_DIRECTORY       = build-doc
CREATE_SUBDIRS         = NO
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
HTML_OUTPUT            = html

INPUT                  = \
  src/kdtree.hpp \
  src/node.hpp \
  src/iterator.hpp \
  src/region.hpp \
  src/function.hpp \
  src/allocator.hpp
FILE_PATTERNS          =
RECURSIVE              = NO
FULL_PATH_NAMES        = NO
STRIP_FROM_PATH        =

JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = NO
MULTILINE_CPP_IS_BRIEF = NO
INHERIT_DOCS           = YES
DISTRIBUTE_GROUP_DOC   = YES

EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
INTERNAL_DOCS          = NO

ENABLED_SECTIONS       =
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = YES
PREDEFINED             = KDTREE_DEFINE_OSTREAM_OPERATORS=1

QUIET                  = YES
WARN_IF_UNDOCUMENTED   = YES

ALIASES                =
EXTENSION_MAPPING      = hpp=C++
